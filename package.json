{
  "name": "essence-despedida",
  "private": true,
  "version": "0.1.0",
  "description": "Juego de mesa web multijugador para la despedida de Javi (estilo Mario Party / Game of Life)",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "smoke": "tsx scripts/smoke.mjs"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
